{
  "name": "todap-server",
  "version": "1.0.0",
  "description": "TODAP — Toplumsal Dayanışma İçin Psikologlar Derneği",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "bash scripts/dev.sh",
    "dev:watch": "node --watch server.js",
    "seed:files": "node scripts/seed-from-files.js",
    "hash": "node scripts/hash-password.js",
    "up": "bash scripts/up.sh",
    "db:stop": "/usr/lib/postgresql/16/bin/pg_ctl -D .pgdata stop || true"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "pg": "^8.13.1"
  }
}
